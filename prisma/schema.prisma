generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String         @id @default(cuid())
  nome          String
  email         String         @unique
  senha         String
  telefone      String?
  cpf           String?        @unique
  conjuge         String?
  conjugeCpf      String?
  conjugeEmail    String?
  conjugeTelefone String?
  banco           String?
  role          String         @default("cliente")
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  financiamento Financiamento?
}

model Financiamento {
  id          String      @id @default(cuid())
  userId      String      @unique
  statusGeral        String      @default("em_andamento")
  motivoCancelamento String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  etapas      Etapa[]
  historico   Historico[]
  pendencias  Pendencia[]
  documentos  Documento[]
}

model Etapa {
  id                  String        @id @default(cuid())
  financiamentoId     String
  nome                String
  ordem               Int
  status              String        @default("aguardando")
  observacoes         String?
  observacoesInternas String?
  dataInicio          DateTime?
  dataConclusao       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  financiamento       Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Pendencia {
  id              String        @id @default(cuid())
  financiamentoId String
  descricao       String
  status          String        @default("aberta")
  criadoEm       DateTime      @default(now())
  concluidoEm     DateTime?
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Documento {
  id              String        @id @default(cuid())
  financiamentoId String
  nome            String
  url             String
  tipo            String
  tamanho         Int
  uploadedBy      String
  createdAt       DateTime      @default(now())
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Historico {
  id              String        @id @default(cuid())
  financiamentoId String
  campo           String
  valorAnterior   String?
  valorNovo       String?
  descricao       String
  criadoPor       String
  createdAt       DateTime      @default(now())
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}
