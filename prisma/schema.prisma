generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Tarefa {
  id              String    @id @default(cuid())
  titulo          String
  descricao       String?
  prioridade      String    @default("media") // baixa | media | alta | urgente
  prioridadeNivel Int       @default(2)       // 1..4 — permite ordenar no banco
  status          String    @default("pendente") // pendente | em_andamento | concluida
  dataLimite      String?   // "YYYY-MM-DD"
  hora            String?   // "HH:MM"
  concluidaEm     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([dataLimite])
}

model Recibo {
  id               String   @id @default(cuid())
  numero           Int      @default(0)
  recebedorNome    String
  recebedorTipoDoc String?
  recebedorDoc     String?
  pagadorNome      String
  pagadorTipoDoc   String?
  pagadorDoc       String?
  valor            Float    @default(0)
  referente        String?
  imovelMatricula  String?
  formaPagamento   String?
  cidade           String?
  data             String?
  createdAt        DateTime @default(now())
}

model DocumentoImportante {
  id          String   @id @default(cuid())
  titulo      String
  descricao   String?
  categoria   String   @default("outro")
  nomeArquivo String
  tamanho     Int
  mimeType    String
  conteudo    Bytes
  uploadedBy  String
  createdAt   DateTime @default(now())
}

model Simulacao {
  id                    String   @id @default(cuid())
  clienteNome           String
  clienteCpf            String?
  clienteRenda          Float?
  clienteDataNascimento String?
  clienteDependentes    Boolean  @default(false)
  clienteTemaFgts       Boolean  @default(false)
  clienteValorFgts      Float?
  tipoFinanciamento     String
  tipoImovel            String
  banco                 String?
  valorImovel           Float?
  valorEntrada          Float?
  subsidio              Float?
  valorParcelaInicial   Float?
  valorParcelaFinal     Float?
  prazo                 Int?
  prazoPeriodo          String?
  taxaJuros             Float?
  taxaPeriodo           String?
  sistemaAmortizacao    String?
  observacoes           String?
  createdAt             DateTime @default(now())
}

model User {
  id            String         @id @default(cuid())
  nome          String
  email         String         @unique
  senha         String
  senhaVisivel  String?
  telefone      String?
  cpf           String?        @unique
  conjuge         String?
  conjugeCpf      String?
  conjugeEmail    String?
  conjugeTelefone String?
  banco           String?
  role          String         @default("cliente")
  avatar        String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  financiamento Financiamento?
}

model Financiamento {
  id          String      @id @default(cuid())
  protocolo   Int         @unique @default(autoincrement())
  userId      String      @unique
  statusGeral        String      @default("em_andamento")
  motivoCancelamento String?
  concluidoEm        DateTime?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  etapas      Etapa[]
  historico   Historico[]
  pendencias  Pendencia[]
  documentos  Documento[]
  avaliacao        Avaliacao?
  financeiroVenda  FinanceiroVenda?
}

model Avaliacao {
  id              String        @id @default(cuid())
  financiamentoId String        @unique
  nota            Int
  recomendaria    Boolean
  comentario      String?
  createdAt       DateTime      @default(now())
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Etapa {
  id                  String        @id @default(cuid())
  financiamentoId     String
  nome                String
  ordem               Int
  status              String        @default("aguardando")
  observacoes         String?
  observacoesInternas String?
  dataInicio          DateTime?
  dataConclusao       DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  financiamento       Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Pendencia {
  id              String        @id @default(cuid())
  financiamentoId String
  descricao       String
  status          String        @default("aberta")
  criadoEm       DateTime      @default(now())
  concluidoEm     DateTime?
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Documento {
  id              String        @id @default(cuid())
  financiamentoId String
  nome            String
  tipo            String
  tamanho         Int
  mimeType        String
  conteudo        Bytes
  uploadedBy      String
  createdAt       DateTime      @default(now())
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model Historico {
  id              String        @id @default(cuid())
  financiamentoId String
  campo           String
  valorAnterior   String?
  valorNovo       String?
  descricao       String
  criadoPor       String
  createdAt       DateTime      @default(now())
  financiamento   Financiamento @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
}

model FinanceiroVenda {
  id              String   @id @default(cuid())
  financiamentoId String   @unique
  tipoVenda       String   @default("financiamento") // "avista" | "financiamento"
  valorImovel     Float?
  dataVenda       DateTime?
  statusVenda     String   @default("em_andamento")

  // Pagamento à Vista
  sinalValor             Float?
  sinalData              DateTime?
  sinalFormaPagamento    String?
  sinalStatus            String?   @default("pendente")
  escrituraValorRestante Float?
  escrituraDataPrevista  DateTime?
  escrituraDataQuitacao  DateTime?
  escrituraStatus        String?   @default("pendente")

  // Financiamento Bancário
  entradaValor           Float?
  entradaData            DateTime?
  entradaFormaPagamento  String?
  usouFgts               Boolean   @default(false)
  fgtsValor              Float?
  bancoFinanciador       String?
  valorFinanciado        Float?
  contratoDataAssinatura DateTime?
  contratoStatus         String?   @default("em_analise")
  valorLiberadoBanco     Float?
  dataLiberacaoBanco     DateTime?

  // Dados bancários / PIX do vendedor
  pixChave         String?
  pixTipo          String?
  contaBanco       String?
  contaAgencia     String?
  contaNumero      String?
  contaTipo        String?
  contaTitular     String?

  // Observação do relatório de pagamento (dados do imóvel, etc.)
  relatorioObservacoes String?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  financiamento   Financiamento         @relation(fields: [financiamentoId], references: [id], onDelete: Cascade)
  comissao        ComissaoImobiliaria?
  historico       HistoricoFinanceiro[]
  contasPagamento ContaPagamento[]
}

model ComissaoImobiliaria {
  id                      String    @id @default(cuid())
  financeiroVendaId       String    @unique
  percentual              Float?
  valor                   Float?
  dataPrevistaRecebimento DateTime?
  dataEfetivaRecebimento  DateTime?
  status                  String    @default("pendente")

  houveAdiantamento Boolean   @default(false)
  valorAdiantado    Float?
  dataAdiantamento  DateTime?
  obsAdiantamento   String?

  houveDivisao        Boolean @default(false)
  percentualPrincipal Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  financeiroVenda FinanceiroVenda        @relation(fields: [financeiroVendaId], references: [id], onDelete: Cascade)
  corretores      CorretorParticipante[]
}

model CorretorParticipante {
  id         String  @id @default(cuid())
  comissaoId String
  nome       String
  creci      String?
  percentual Float?
  valor      Float?

  comissao ComissaoImobiliaria @relation(fields: [comissaoId], references: [id], onDelete: Cascade)
}

model HistoricoFinanceiro {
  id                String   @id @default(cuid())
  financeiroVendaId String
  descricao         String
  usuario           String
  createdAt         DateTime @default(now())

  financeiroVenda FinanceiroVenda @relation(fields: [financeiroVendaId], references: [id], onDelete: Cascade)
}

model ContaPagamento {
  id                String          @id @default(cuid())
  financeiroVendaId String
  tipo              String          // "vendedor" | "imobiliaria"
  descricao         String?
  formaPagamento    String?         // "pix" | "ted" | "doc" | "dinheiro"
  pixChave          String?
  pixTipo           String?
  banco             String?
  agencia           String?
  numero            String?
  contaTipo         String?
  titular           String?
  documento         String?
  valor             Float?
  ordem             Int             @default(0)
  createdAt         DateTime        @default(now())

  financeiroVenda   FinanceiroVenda @relation(fields: [financeiroVendaId], references: [id], onDelete: Cascade)
}

model LancamentoFinanceiro {
  id             String   @id @default(cuid())
  descricao      String
  valor          Float
  tipo           String   // "receita" | "despesa"
  categoria      String
  data           DateTime
  formaPagamento String?  // "pix" | "credito" | "debito" | "dinheiro"
  parcelas       Int?     // apenas quando formaPagamento = "credito"
  observacao     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model LancamentoPessoal {
  id             String   @id @default(cuid())
  descricao      String
  valor          Float
  tipo           String   // "receita" | "despesa"
  categoria      String
  data           DateTime
  formaPagamento String?  // "pix" | "credito" | "debito" | "dinheiro"
  parcelas       Int?     // apenas quando formaPagamento = "credito"
  observacao     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}
