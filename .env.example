# Database - SQLite for dev, PostgreSQL for production
DATABASE_URL="file:./dev.db"

# PostgreSQL (Supabase) for production:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# JWT Secret (use a strong random string in production)
JWT_SECRET="sua-chave-secreta-super-segura-mude-em-producao"

# Next.js
NEXTAUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Upload de Arquivos (opcional - Supabase Storage)
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Email (recuperação de senha) — https://resend.com
RESEND_API_KEY="re_sua_chave_api_resend"
SMTP_FROM="noreply@emobe.com.br"
SMTP_FROM_NAME="Portal Emobe"
